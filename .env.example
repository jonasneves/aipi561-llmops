# copy to .env and fill.
# This project bills to the ops-ai-jonas GCP project (same one Project 1's GKE
# infra lives in) so the API runs on the paid tier off course credits.
# Mint a key scoped to that project:
#   gcloud services enable generativelanguage.googleapis.com --project ops-ai-jonas
#   gcloud services api-keys create --display-name="aipi561-llmops gemini" \
#     --api-target=service=generativelanguage.googleapis.com --project ops-ai-jonas
# (A free key from https://aistudio.google.com/app/apikey also works, but hits
#  free-tier daily caps.)
GOOGLE_CLOUD_PROJECT=ops-ai-jonas
GOOGLE_API_KEY=AIza...
